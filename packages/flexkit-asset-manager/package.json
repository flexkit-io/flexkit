{
  "name": "@flexkit/asset-manager",
  "version": "0.0.19",
  "description": "Flexkit plugin for browsing and managing assets in a project.",
  "keywords": [
    "flexkit",
    "studio",
    "react",
    "node",
    "assets",
    "flexkit-plugin"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "style": "dist/index.css",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flexkit-io/flexkit",
    "directory": "packages/flexkit-asset-manager"
  },
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server/index.js",
    "./tailwind.config": "./tailwind.config.ts",
    "./styles.css": "./dist/index.css"
  },
  "typesVersions": {
    "*": {
      "server": [
        "./dist/server/index.d.ts"
      ]
    }
  },
  "sideEffects": [
    "**/*.css",
    "./dist/index.css"
  ],
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tailwindcss -i ./src/styles.css -o dist/index.css && tsup src/index.tsx --format esm --dts --external react",
    "dev": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch=always & tsup src/index.tsx --format esm --watch --dts --external react",
    "lint": "eslint \"src/**/*.ts*\"",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@flexkit/studio": "workspace:*",
    "@tailwindcss/cli": "4.2.4",
    "@types/node": "^20.5.2",
    "@types/ramda": "^0.29.7",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-file-icon": "1.0.4",
    "eslint-config-custom": "workspace:*",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-config": "workspace:*",
    "tailwindcss": "4.2.4",
    "tsconfig": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "lucide-react": "0.577.0",
    "ramda": "^0.29.1",
    "react-file-icon": "1.6.0",
    "swr": "2.4.1"
  },
  "peerDependencies": {
    "@flexkit/studio": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
